datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id               String    @id @default(cuid())
  name             String?
  email            String    @unique
  password         String?
  emailVerified    DateTime?
  image            String?
  role             String    @default("USER") // ADMIN, USER
  gender           String?
  age              Int?
  address          String?   @db.Text
  points           Int       @default(0)
  wins             Int       @default(0)
  losses           Int       @default(0)
  preferredAvatar  String?   @default("warlord")
  
  accounts         Account[]
  sessions         Session[]
  
  // Subscriptions & Perks
  subscriptionId   String?
  subscription     Subscription? @relation(fields: [subscriptionId], references: [id])
  subscribedAt     DateTime?
  subscriptionEnd  DateTime?
  
  // Growth & Social
  referralCode     String?   @unique
  referredBy       String?
  friendshipsInitiated Friendship[] @relation("UserFriendships")
  friendshipsReceived  Friendship[] @relation("FriendFriendships")
  invitationsSent      EmailInvitation[] @relation("UserInvitations")
  
  // For Tiered access (Chaos/Destruction)
  userSelections   UserActSelection[]
  
  // RoastBuddy & Notifications
  notifications    Notification[]
  roastRoomMembers RoastRoomMember[]
  
  // Tic-Tac-Toe Duels
  player1Duels     TicTacToeDuel[] @relation("Player1Duels")
  player2Duels     TicTacToeDuel[] @relation("Player2Duels")
  
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String   @db.Text
  type      String   // ROAST, INVITE, SYSTEM
  isRead    Boolean  @default(false)
  link      String?  // Optional link to the room or act
  createdAt DateTime @default(now())
  
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RoastRoom {
  id        String   @id @default(cuid())
  name      String?
  isGroup   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  members   RoastRoomMember[]
  messages  RoastMessage[]
}

model RoastRoomMember {
  id        String   @id @default(cuid())
  roomId    String
  userId    String
  role      String?  @default("Performer") // Heckler, Target, Clown King, etc.
  avatar    String?  @default("🤡")         // Circus-themed emoji/icon
  
  room      RoastRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([roomId, userId])
}

model RoastMessage {
  id         String   @id @default(cuid())
  roomId     String
  senderId   String
  senderName String
  content    String   @db.Text
  isTemplate Boolean  @default(false)
  emoji      String?
  createdAt  DateTime @default(now())
  
  room       RoastRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
}

model Subscription {
  id               String   @id @default(cuid())
  name             String   // Chaos, Destruction, Annihilation
  tier             String   // CHAOS, DESTRUCTION, ANNIHILATION
  priceMonthly     Float
  priceYearly      Float
  maxActs          Int      // 3, 5, or -1 (unlimited)
  features         String   @db.Text // JSON string of features
  
  users            User[]
  actConfigs       SubscriptionActConfig[]
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model SubscriptionActConfig {
  id              String    @id @default(cuid())
  subscriptionId  String
  actId           String
  isAvailable     Boolean   @default(true)
  isFree          Boolean   @default(false)
  freeUntil       DateTime? // Time-limited free access
  
  subscription    Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  act             Act          @relation(fields: [actId], references: [id], onDelete: Cascade)

  @@unique([subscriptionId, actId])
}

model UserActSelection {
  id               String   @id @default(cuid())
  userId           String
  actId            String
  selectedAt       DateTime @default(now())
  canChangeAfter   DateTime
  
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  act              Act      @relation(fields: [actId], references: [id])

  @@unique([userId, actId])
}

model Act {
  id               String   @id @default(cuid())
  name             String
  description      String   @db.Text
  emoji            String
  isActive         Boolean  @default(true)
  isSystem         Boolean  @default(false) // Legacy globally free flag
  
  // Relations
  userSelections   UserActSelection[]
  subscriptionConfigs SubscriptionActConfig[]
  
  // AI Config for this specific act
  aiModelId        String?
  aiModel          AIModel? @relation(fields: [aiModelId], references: [id])
  
  createdAt        DateTime @default(now())
}

model AIModel {
  id               String   @id @default(cuid())
  name             String   // OpenAI, Groq, Anthropic, etc.
  modelName        String   // gpt-4, llama-3, etc.
  apiKey           String   // Encrypted or managed via ENV
  apiUrl           String?
  isActive         Boolean  @default(false)
  isGlobalDefault  Boolean  @default(false)
  
  acts             Act[]
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

// NextAuth Models
model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String? @db.Text
  access_token       String? @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String? @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model AuditLog {
  id          String   @id @default(cuid())
  adminId     String
  adminName   String
  action      String
  details     String   @db.Text
  targetId    String?
  targetName  String?
  createdAt   DateTime @default(now())
}

model Friendship {
  id        String   @id @default(cuid())
  userId    String
  friendId  String
  status    String   @default("PENDING") // PENDING, ACCEPTED, REJECTED
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  message   String?   @db.Text
  
  user      User     @relation("UserFriendships", fields: [userId], references: [id], onDelete: Cascade)
  friend    User     @relation("FriendFriendships", fields: [friendId], references: [id], onDelete: Cascade)

  @@unique([userId, friendId])
}

model EmailInvitation {
  id          String   @id @default(cuid())
  inviterId   String
  email       String
  token       String   @unique
  status      String   @default("PENDING") // PENDING, ACCEPTED
  createdAt   DateTime @default(now())
  message     String?   @db.Text
  
  inviter     User     @relation("UserInvitations", fields: [inviterId], references: [id], onDelete: Cascade)
}
model TicTacToeDuel {
  id          String   @id @default(cuid())
  player1Id   String
  player2Id   String
  board       String   @default("null,null,null,null,null,null,null,null,null")
  turnId      String   // The ID of the user whose turn it is
  winnerId    String?
  status      String   @default("PENDING") // PENDING, ACTIVE, COMPLETED, ABANDONED, REJECTED
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  player1     User     @relation("Player1Duels", fields: [player1Id], references: [id])
  player2     User     @relation("Player2Duels", fields: [player2Id], references: [id])
}
