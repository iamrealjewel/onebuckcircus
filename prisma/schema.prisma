datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id               String    @id @default(cuid())
  name             String?
  email            String    @unique
  password         String?
  emailVerified    DateTime?
  image            String?
  role             String    @default("USER") // ADMIN, USER
  gender           String?
  age              Int?
  address          String?   @db.Text
  
  accounts         Account[]
  sessions         Session[]
  
  // Subscriptions & Perks
  subscriptionId   String?
  subscription     Subscription? @relation(fields: [subscriptionId], references: [id])
  subscribedAt     DateTime?
  subscriptionEnd  DateTime?
  
  // Growth & Social
  referralCode     String?   @unique
  referredBy       String?
  friendshipsInitiated Friendship[] @relation("UserFriendships")
  friendshipsReceived  Friendship[] @relation("FriendFriendships")
  invitationsSent      EmailInvitation[] @relation("UserInvitations")
  
  // For Tiered access (Chaos/Destruction)
  selectedApps     UserActSelection[]
  
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model Subscription {
  id               String   @id @default(cuid())
  name             String   // Chaos, Destruction, Annihilation
  tier             String   // CHAOS, DESTRUCTION, ANNIHILATION
  priceMonthly     Float
  priceYearly      Float
  maxActs          Int      // 3, 5, or -1 (unlimited)
  features         String   @db.Text // JSON string of features
  
  users            User[]
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model UserActSelection {
  id               String   @id @default(cuid())
  userId           String
  actId            String
  selectedAt       DateTime @default(now())
  canChangeAfter   DateTime
  
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  act              Act      @relation(fields: [actId], references: [id])

  @@unique([userId, actId])
}

model Act {
  id               String   @id @default(cuid())
  name             String
  description      String   @db.Text
  emoji            String
  isActive         Boolean  @default(true)
  
  // AI Config for this specific act
  aiModelId        String?
  aiModel          AIModel? @relation(fields: [aiModelId], references: [id])
  
  userSelections   UserActSelection[]
  
  createdAt        DateTime @default(now())
}

model AIModel {
  id               String   @id @default(cuid())
  name             String   // OpenAI, Groq, Anthropic, etc.
  modelName        String   // gpt-4, llama-3, etc.
  apiKey           String   // Encrypted or managed via ENV
  apiUrl           String?
  isActive         Boolean  @default(false)
  isGlobalDefault  Boolean  @default(false)
  
  acts             Act[]
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

// NextAuth Models
model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String? @db.Text
  access_token       String? @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String? @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model AuditLog {
  id          String   @id @default(cuid())
  adminId     String
  adminName   String
  action      String
  details     String   @db.Text
  targetId    String?
  targetName  String?
  createdAt   DateTime @default(now())
}

model Friendship {
  id        String   @id @default(cuid())
  userId    String
  friendId  String
  status    String   @default("PENDING") // PENDING, ACCEPTED, REJECTED
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  message   String?   @db.Text
  
  user      User     @relation("UserFriendships", fields: [userId], references: [id], onDelete: Cascade)
  friend    User     @relation("FriendFriendships", fields: [friendId], references: [id], onDelete: Cascade)

  @@unique([userId, friendId])
}

model EmailInvitation {
  id          String   @id @default(cuid())
  inviterId   String
  email       String
  token       String   @unique
  status      String   @default("PENDING") // PENDING, ACCEPTED
  createdAt   DateTime @default(now())
  message     String?   @db.Text
  
  inviter     User     @relation("UserInvitations", fields: [inviterId], references: [id], onDelete: Cascade)
}
